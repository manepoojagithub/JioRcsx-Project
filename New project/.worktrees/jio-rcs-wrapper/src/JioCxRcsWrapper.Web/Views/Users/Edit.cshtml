@model JioCxRcsWrapper.Web.Models.Users.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><h1 class="h4 mb-0">Edit User</h1></div>
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label asp-for="RoleId" class="form-label">Role</label>
                        <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ClientId" class="form-label">Client</label>
                        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
                    </div>
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                    <div class="form-check mt-2">
                        <input asp-for="IsDeveloper" class="form-check-input" />
                        <label asp-for="IsDeveloper" class="form-check-label">IsDeveloper</label>
                    </div>
                </div>
                <div class="card-footer d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
