@model JioCxRcsWrapper.Application.Common.Pagination.PagedResult<JioCxRcsWrapper.Application.Users.UserSummary>
@inject JioCxRcsWrapper.Web.Services.PermissionUiService PermissionUi
@{
    ViewData["Title"] = "User Management";
    var canAdd = await PermissionUi.CanAsync("Users", "Add");
    var canUpdate = await PermissionUi.CanAsync("Users", "Update");
    var canDisable = await PermissionUi.CanAsync("Users", "Disable");
    var canDelete = await PermissionUi.CanAsync("Users", "Delete");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">User Management</h1>
        <p class="text-muted mb-0">Create and manage panel users.</p>
    </div>
    <div class="d-flex gap-2">
        @if (canUpdate)
        {
            <a asp-action="Permissions" class="btn btn-outline-primary">Menu Permissions</a>
        }
        @if (canAdd)
        {
            <a asp-action="Create" class="btn btn-primary">Create User</a>
        }
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>
                Name
                <input type="text" class="form-control form-control-sm grid-filter" data-column="Name" value="@ViewContext.HttpContext.Request.Query["Name"]" placeholder="Filter..." />
            </th>
            <th>
                Email
                <input type="text" class="form-control form-control-sm grid-filter" data-column="Email" value="@ViewContext.HttpContext.Request.Query["Email"]" placeholder="Filter..." />
            </th>
            <th>
                Role
                <input type="text" class="form-control form-control-sm grid-filter" data-column="Role" value="@ViewContext.HttpContext.Request.Query["Role"]" placeholder="Filter..." />
            </th>
            <th>
                Client
                <input type="text" class="form-control form-control-sm grid-filter" data-column="Client" value="@ViewContext.HttpContext.Request.Query["Client"]" placeholder="Filter..." />
            </th>
            <th>Status</th>
            <th>Developer</th>
            <th>Created</th>
            <th class="text-end action-cell">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Items)
        {
            <tr>
                <td>@user.Name</td>
                <td>@user.Email</td>
                <td>@user.Role</td>
                <td>@(user.Client ?? "-")</td>
                <td><span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">@(user.IsActive ? "Active" : "Inactive")</span></td>
                <td>@(user.IsDeveloper ? "Yes" : "No")</td>
                <td>@user.CreatedAt.ToLocalTime().ToString("g")</td>
                <td class="text-end action-cell">
                    <div class="action-stack">
                    @if (canUpdate)
                    {
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    }
                    @if (canDisable && user.IsActive)
                    {
                        <form asp-action="Disable" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Disable this user?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-warning">Disable</button>
                        </form>
                    }
                    @if (canDelete)
                    {
                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<partial name="_Pager" model="Model" />
