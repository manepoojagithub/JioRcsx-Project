@model JioCxRcsWrapper.Application.Common.Pagination.PagedResult<JioCxRcsWrapper.Domain.Entities.MessageTemplate>
@{
    ViewData["Title"] = "Message Builder";
    var clients = (Dictionary<int, string>)ViewBag.Clients;
}

<section class="page-hero panel-hero">
    <div>
        <div class="page-eyebrow">Template Management</div>
        <h1>Message Builder</h1>
        <p>Design multi-card carousels, rich media cards, and interactive text messages.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary panel-primary-btn">Create Template</a>
</section>

<section class="metric-strip">
    <article class="metric-tile"><span>Plain Text</span><strong>@ViewBag.PlainText</strong></article>
    <article class="metric-tile"><span>Standalone Cards</span><strong>@ViewBag.StandaloneCards</strong></article>
    <article class="metric-tile"><span>Carousels</span><strong>@ViewBag.Carousels</strong></article>
</section>

<div class="template-grid mt-4">
    @foreach (var template in Model.Items)
    {
        <div class="template-card">
            <div class="template-preview-box">
                @if (template.MessageType == JioCxRcsWrapper.Domain.Enums.MessageType.PlainText)
                {
                    <div class="preview-text-only">
                        <i class="bi bi-chat-left-text"></i>
                        <span>Text Message</span>
                    </div>
                }
                else if (template.MessageType == JioCxRcsWrapper.Domain.Enums.MessageType.StandaloneCard)
                {
                    <div class="preview-card-only">
                        @if (!string.IsNullOrEmpty(template.LocalMediaPath))
                        {
                            <img src="@template.LocalMediaPath" alt="Preview" onerror="this.src='@(template.RcsMediaUrl ?? "")'; this.onerror=null;" />
                        }
                        else if (!string.IsNullOrEmpty(template.RcsMediaUrl))
                        {
                            <img src="@template.RcsMediaUrl" alt="Preview" />
                        }
                        else
                        {
                            <i class="bi bi-card-image"></i>
                        }
                    </div>
                }
                else if (template.MessageType == JioCxRcsWrapper.Domain.Enums.MessageType.Carousel)
                {
                    <div class="preview-carousel-only">
                        @if (!string.IsNullOrEmpty(template.LocalMediaPath))
                        {
                            <img src="@template.LocalMediaPath" alt="Preview" class="opacity-50" onerror="this.src='@(template.RcsMediaUrl ?? "")'; this.onerror=null;" />
                        }
                        else if (!string.IsNullOrEmpty(template.RcsMediaUrl))
                        {
                            <img src="@template.RcsMediaUrl" alt="Preview" class="opacity-50" />
                        }
                        <div class="carousel-overlay">
                            <i class="bi bi-collection"></i>
                            <span>Carousel</span>
                        </div>
                    </div>
                }
            </div>
            <div class="template-info">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h3>@template.Name</h3>
                        <p class="text-muted small mb-0">Agent: @(template.ClientId.HasValue && clients.TryGetValue(template.ClientId.Value, out var agent) ? agent : "Global")</p>
                    </div>
                    <span class="badge bg-light text-dark border">@template.MessageType</span>
                </div>
                <div class="template-actions mt-3">
                    <a asp-action="Edit" asp-route-id="@template.Id" class="btn btn-sm btn-outline-primary w-100 mb-2">Edit Template</a>
                    <form asp-action="Delete" asp-route-id="@template.Id" method="post" onsubmit="return confirm('Delete this template?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-link text-danger w-100 p-0 text-decoration-none">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.TotalItems == 0)
{
    <div class="text-center py-5 bg-light rounded border border-dashed">
        <i class="bi bi-plus-circle display-1 text-muted opacity-25"></i>
        <h2 class="h5 mt-3">No templates yet</h2>
        <p class="text-muted">Create your first message template to start a campaign.</p>
        <a asp-action="Create" class="btn btn-primary btn-sm mt-2">Create Now</a>
    </div>
}

<partial name="_Pager" model="Model" />

<style>
    .template-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    .template-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e9ecef;
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        flex-direction: column;
    }
    .template-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }
    .template-preview-box {
        height: 160px;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-bottom: 1px solid #f1f3f5;
        position: relative;
    }
    .template-preview-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .template-preview-box i {
        font-size: 3rem;
        color: #dee2e6;
    }
    .preview-text-only, .preview-carousel-only {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }
    .preview-text-only span, .preview-carousel-only span {
        font-size: 0.8rem;
        color: #adb5bd;
        font-weight: 500;
        text-transform: uppercase;
    }
    .carousel-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        background: rgba(255,255,255,0.4);
    }
    .template-info {
        padding: 1.25rem;
        flex-grow: 1;
    }
    .template-info h3 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>
