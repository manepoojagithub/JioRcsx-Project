@model JioCxRcsWrapper.Web.Models.Clients.EditClientViewModel

@{
    ViewData["Title"] = "Update Client";
}

<section class="page-hero setup-hero">
    <div>
        <div class="page-eyebrow">Client Update</div>
        <h1>Update Company Information</h1>
        <p>Maintain agent identity, branding, and encrypted JioCX credentials.</p>
    </div>
</section>

<form asp-action="Edit" method="post" enctype="multipart/form-data" class="panel-form">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="LogoPath" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="panel-card form-section">
        <div class="panel-card-header">
            <div>
                <h2>Basic Information</h2>
                <p>Public brand and JioCX agent identity.</p>
            </div>
        </div>
        <div class="form-grid">
            <div><label asp-for="BrandName" class="form-label"></label><input asp-for="BrandName" class="form-control" /></div>
            <div><label asp-for="AgentName" class="form-label"></label><input asp-for="AgentName" class="form-control" /></div>
            <div>
                <label class="form-label">Agent ID</label>
                <div class="input-group">
                    <input type="password" name="AgentId" class="form-control" id="agentIdInput" value="@Model.AgentId" />
                    <button class="btn btn-outline-secondary" type="button" onclick="toggleVisibility(event, 'agentIdInput')">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <div class="form-text">Masked value keeps the existing Agent ID. Replace it only when changing credentials.</div>
            </div>
            <div><label asp-for="SiteName" class="form-label"></label><input asp-for="SiteName" class="form-control" /></div>
            <div>
                <label asp-for="AgentUseCase" class="form-label">Agent Use Case</label>
                <select asp-for="AgentUseCase" class="form-select">
                    <option value="Transactional">Transactional</option>
                    <option value="Promotional">Promotional</option>
                    <option value="OTP">OTP</option>
                </select>
            </div>
            <div><label asp-for="ManagerEmail" class="form-label">Manager Email</label><input asp-for="ManagerEmail" class="form-control" /></div>
            <div>
                <label class="form-label">Manager Password</label>
                <div class="input-group">
                    <input type="password" name="ManagerPassword" class="form-control" id="managerPasswordInput" readonly value="@Model.ManagerPassword" />
                    <button class="btn btn-outline-secondary" type="button" onclick="toggleVisibility(event, 'managerPasswordInput')">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            </div>
            <div class="d-flex align-items-center mt-4">
                <div class="form-check form-switch">
                    <input asp-for="WebhookAuditEnabled" class="form-check-input" type="checkbox">
                    <label asp-for="WebhookAuditEnabled" class="form-check-label">Enable Webhook Audit</label>
                </div>
            </div>
        </div>
    </section>

    <section class="panel-card form-section">
        <div class="panel-card-header">
            <div>
                <h2>Branding</h2>
                <p>Upload a new logo only when the current branding needs to change.</p>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
        {
            <div class="mb-3">
                <img src="@Model.LogoPath" alt="Current logo" style="max-height:72px" class="rounded border bg-white p-2" />
            </div>
        }
        <div><label asp-for="LogoFile" class="form-label">Logo</label><input asp-for="LogoFile" class="form-control" type="file" accept="image/*" /></div>
    </section>

    <section class="panel-card form-section">
        <div class="panel-card-header">
            <div>
                <h2>JioCX Credentials</h2>
                <p>Leave Agent Key blank to keep the existing encrypted key.</p>
            </div>
        </div>
        <div>
            <label class="form-label">Agent Key</label>
            <div class="input-group">
                <input type="password" name="AgentKey" class="form-control" id="agentKeyInput" value="@Model.AgentKey" />
                <button class="btn btn-outline-secondary" type="button" onclick="toggleVisibility(event, 'agentKeyInput')">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <div class="form-text">Masked value keeps the existing encrypted API key.</div>
        </div>
    </section>

    <section class="panel-card form-section">
        <div class="panel-card-header">
            <div>
                <h2>Credit Settings</h2>
                <p>Changes apply to the client and its manager users.</p>
            </div>
        </div>
        <div class="form-grid">
            <div><label asp-for="Credits" class="form-label"></label><input asp-for="Credits" class="form-control" /></div>
            <div><label asp-for="CreditCostPerMessage" class="form-label">Credits Per Successful Message</label><input asp-for="CreditCostPerMessage" class="form-control" /></div>
            <div><label asp-for="LowCreditThreshold" class="form-label">Low Credit Warning Threshold</label><input asp-for="LowCreditThreshold" class="form-control" /></div>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary panel-primary-btn">Update Client</button>
        <a asp-action="Index" class="btn btn-light panel-soft-btn">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleVisibility(event, inputId) {
            const input = document.getElementById(inputId);
            const button = event.currentTarget;
            const icon = button.querySelector('i');
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = "password";
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}
