@inject JioCxRcsWrapper.Application.Clients.IBrandingService BrandingService
@inject JioCxRcsWrapper.Application.Security.ICurrentUser CurrentUser
@inject JioCxRcsWrapper.Application.Security.IUserCreditService CreditService
@{
    var branding = await BrandingService.GetBrandingAsync(CurrentUser.ClientId);
    var siteName = string.IsNullOrWhiteSpace(branding.SiteName) ? "Advait Services" : branding.SiteName;
    var brandInitial = siteName.Trim()[0].ToString().ToUpperInvariant();
    var creditInfo = await CreditService.GetCurrentUserCreditsAsync();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteName</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/JioCxRcsWrapper.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @if (creditInfo != null)
    {
        if (creditInfo.Credits <= 0)
        {
            <div class="alert alert-danger mb-0 text-center rounded-0 py-2" style="position: sticky; top: 0; z-index: 2000;">
                <strong>Credits Alert:</strong> You have 0 credits. Please contact support to add credits.
            </div>
        }
        else if (creditInfo.Credits < creditInfo.LowCreditThreshold)
        {
            <div class="alert alert-warning mb-0 text-center rounded-0 py-2" style="position: sticky; top: 0; z-index: 2000;">
                <strong>Credits Warning:</strong> Your credits are low (@creditInfo.Credits). Please top up soon.
            </div>
        }
    }
    <div class="app-shell">
        <aside class="app-sidebar" id="app-sidebar">
            <div class="app-brand-row">
                <a class="app-brand" asp-controller="Dashboard" asp-action="Index">
                    @if (!string.IsNullOrWhiteSpace(branding.LogoPath))
                    {
                        <img class="app-brand-logo" src="@branding.LogoPath" alt="@siteName logo" />
                    }
                    else
                    {
                        <span class="app-brand-mark">@brandInitial</span>
                    }
                    <span class="app-brand-text">@siteName</span>
                </a>
                <button type="button" class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar" aria-expanded="true">
                    <span></span>
                </button>
            </div>
            <partial name="_Sidebar" />
        </aside>
        <div class="app-main">
            <div class="app-topbar">
                <div class="fw-semibold">@ViewData["Title"]</div>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        @User.Identity?.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item">Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
            <main role="main" class="app-content">
                <div id="global-alert" class="alert d-none"></div>
            @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
