@model JioCxRcsWrapper.Web.Models.Campaigns.DetailsViewModel
@using System.Text.Json
@using JioCxRcsWrapper.Domain.Enums
@{
    ViewData["Title"] = "Campaign Details";
}

@if (Model.Campaign != null)
{
<section class="page-hero dark-hero">
    <div>
        <div class="page-eyebrow">Campaign Audit</div>
        <h1>@Model.Campaign.Name</h1>
        <p>Comprehensive overview of configuration, message content, and delivery performance.</p>
    </div>
    <div class="hero-actions">
        <a asp-action="Index" class="btn btn-light panel-soft-btn">Back to List</a>
    </div>
</section>

<div class="row mt-n5">
    <div class="col-lg-4">
        <section class="panel-card shadow-lg mb-4">
            <div class="panel-card-header">
                <div>
                    <h2>Campaign Info</h2>
                    <p>Core configuration settings.</p>
                </div>
            </div>
            <div class="p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Status</label>
                    <div><span class="status-pill status-active">@Model.Campaign.Status</span></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Client</label>
                    <div class="form-control-plaintext">@Model.Campaign.ClientName</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Type</label>
                    <div class="form-control-plaintext">@Model.Campaign.Type</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Scheduled At</label>
                    <div class="form-control-plaintext">@(Model.Campaign.ScheduledAt?.ToLocalTime().ToString("f") ?? "Immediate")</div>
                </div>
            </div>
        </section>
    </div>

    <div class="col-lg-8">
        @if (Model.Template != null)
        {
            var payload = JsonDocument.Parse(Model.Template.PayloadJson);
            var content = payload.RootElement.GetProperty("content");

            <section class="panel-card shadow-lg mb-4">
                <div class="panel-card-header">
                    <div>
                        <h2>Message Content</h2>
                        <p>Template used for this campaign.</p>
                    </div>
                </div>
                <div class="p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Template Name</label>
                        <div class="form-control-plaintext">@Model.Template.Name</div>
                    </div>
                    @if (Model.Template.MessageType == MessageType.PlainText)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Text</label>
                            <div class="form-control-plaintext">@Html.Raw(content.GetProperty("plainText").GetString())</div>
                        </div>
                    }
                    else if (Model.Template.MessageType == MessageType.RichCard)
                    {
                        var richCard = content.GetProperty("richCardDetails").GetProperty("standalone").GetProperty("content");
                        <div class="mb-3">
                            <label class="form-label fw-bold">Title</label>
                            <div class="form-control-plaintext">@Html.Raw(richCard.GetProperty("cardTitle").GetString())</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Description</label>
                            <div class="form-control-plaintext">@Html.Raw(richCard.GetProperty("cardDescription").GetString())</div>
                        </div>
                        @if (richCard.TryGetProperty("cardMedia", out var media) && media.GetProperty("contentInfo").TryGetProperty("fileUrl", out var fileUrl))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Media</label>
                                <div>
                                    <a href="@fileUrl.GetString()" target="_blank">
                                        <img src="@fileUrl.GetString()" class="img-fluid" style="max-height: 200px;" />
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>
        }

        <section class="panel-card shadow-lg">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h2>Recipient Tracking</h2>
                    <p>Detailed status for every contact.</p>
                </div>
            </div>
            <div class="table-responsive" style="max-height: 500px;">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Mobile Number</th>
                            <th>Status</th>
                            <th>Diagnostic Code</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Contacts != null)
                        {
                            @foreach (var contact in Model.Contacts)
                            {
                                <tr>
                                    <td class="font-monospace">@contact.MobileNumber</td>
                                    <td>
                                        <span class="badge bg-light @(contact.StatusText == "Delivered" || contact.StatusText == "Sent" ? "text-success" : (contact.StatusText == "Failed" ? "text-danger" : "text-secondary")) border">@contact.StatusText</span>
                                    </td>
                                    <td class="small text-muted font-monospace">@(contact.ErrorCode ?? "-")</td>
                                </tr>
                            }
                            @if (!Model.Contacts.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-5 text-muted">
                                        <i class="bi bi-people h1 d-block opacity-25"></i>
                                        No contacts found for this campaign.
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="bi bi-people h1 d-block opacity-25"></i>
                                    No contacts found for this campaign.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
}
else
{
    <div class="alert alert-danger">Campaign not found.</div>
}
