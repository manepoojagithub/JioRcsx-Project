@model JioCxRcsWrapper.Web.Models.Campaigns.CreateCampaignViewModel
@using JioCxRcsWrapper.Application.Templates
@{
    ViewData["Title"] = "Create Campaign";
    var templates = (IReadOnlyList<MessageTemplateSummary>)(ViewBag.Templates ?? Array.Empty<MessageTemplateSummary>());
}

<section class="page-hero panel-hero">
    <div>
        <div class="page-eyebrow">Campaign Setup</div>
        <h1>Create Campaign</h1>
        <p>Select message template, schedule type, and one or many phone numbers for RCSX delivery.</p>
    </div>
</section>

<form asp-action="Create" method="post" class="panel-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-4">
        <div class="col-md-6">
            <section class="panel-card form-section h-100 mb-0">
                <div class="panel-card-header">
                    <div>
                        <h2>Campaign Information</h2>
                        <p>Give this send a clear operational name and client scope.</p>
                    </div>
                    <span class="section-count">01</span>
                </div>
                <div class="form-grid">
                    <div>
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="ClientId" class="form-label">Client</label>
                        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select" id="ClientIdSelect"></select>
                        <span asp-validation-for="ClientId" class="text-danger"></span>
                    </div>
                </div>
            </section>
        </div>
        <div class="col-md-6">
            <section class="panel-card form-section h-100 mb-0">
                <div class="panel-card-header">
                    <div>
                        <h2>Send Rules</h2>
                        <p>Choose one-time, scheduled, or recurring behavior.</p>
                    </div>
                    <span class="section-count">02</span>
                </div>
                <div class="form-grid">
                    <div>
                        <label asp-for="Type" class="form-label"></label>
                        <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<JioCxRcsWrapper.Domain.Enums.CampaignType>()"></select>
                    </div>
                    <div>
                        <label asp-for="ScheduledAt" class="form-label"></label>
                        <input asp-for="ScheduledAt" type="datetime-local" class="form-control" />
                    </div>
                </div>
                <div class="form-check form-switch mt-3">
                    <input asp-for="IsRCSEnabled" class="form-check-input" type="checkbox" />
                    <label asp-for="IsRCSEnabled" class="form-check-label">IsRCSEnabled</label>
                    <div class="form-text">Uncheck this to skip JioCX RCS number verification before queueing.</div>
                </div>
            </section>
        </div>
        <div class="col-md-6">
            <section class="panel-card form-section h-100 mb-0">
                <div class="panel-card-header">
                    <div>
                        <h2>Message Template</h2>
                        <p>Use a send-ready payload from Message Builder.</p>
                    </div>
                    <span class="section-count">03</span>
                </div>
                <div>
                    <label asp-for="TemplateId" class="form-label">Message Template</label>
                    <select asp-for="TemplateId" class="form-select" id="TemplateId">
                        <option value="">None</option>
                        @foreach (var template in templates)
                        {
                            <option value="@template.Id" data-client-id="@(template.ClientId?.ToString() ?? string.Empty)">
                                @template.Name (@template.MessageType) - @template.ClientName
                            </option>
                        }
                    </select>
                    <div class="form-text">Only Global templates and templates created for the selected client can be sent.</div>
                </div>
            </section>
        </div>
        <div class="col-md-6">
            <section class="panel-card form-section h-100 mb-0">
                <div class="panel-card-header">
                    <div>
                        <h2>Message Preview</h2>
                        <p>Visual representation of the selected template.</p>
                    </div>
                    <span class="section-count">04</span>
                </div>
                <div id="template-preview" class="p-3">
                    <div class="border rounded p-3 bg-light text-center text-muted">Select a template to see preview</div>
                </div>
            </section>
        </div>
        <div class="col-md-12">
            <section class="panel-card form-section campaign-phone-panel">
                <div class="panel-card-header">
                    <div>
                        <h2>Recipients</h2>
                        <p>Enter one or many JioCX-supported E.164 phone numbers.</p>
                    </div>
                    <span class="section-count">05</span>
                </div>
                <label asp-for="PhoneNumbers" class="form-label">Phone Number(s)</label>
                <textarea asp-for="PhoneNumbers" class="form-control" rows="5" placeholder="+918000000000, +918000000001"></textarea>
                <div class="form-text">Separate by comma, semicolon, or new line. CSV upload remains available after creation.</div>
            </section>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary panel-primary-btn">Create Campaign</button>
        <a asp-action="Index" class="btn btn-light panel-soft-btn">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const clientSelect = document.getElementById("ClientIdSelect");
            const templateSelect = document.getElementById("TemplateId");
            const templatePreview = document.getElementById("template-preview");

            if (!clientSelect || !templateSelect) return;

            function filterTemplates() {
                const clientId = clientSelect.value;
                let selectedVisible = false;
                Array.from(templateSelect.options).forEach(option => {
                    const templateClientId = option.dataset.clientId || "";
                    const visible = !option.value || !templateClientId || templateClientId === clientId;
                    option.hidden = !visible;
                    option.disabled = !visible;
                    if (option.selected && visible) selectedVisible = true;
                });

                if (!selectedVisible) {
                    templateSelect.value = "";
                }
                updatePreview();
            }

            async function updatePreview() {
                const templateId = templateSelect.value;
                if (!templateId) {
                    templatePreview.innerHTML = '<div class="border rounded p-3 bg-light text-center text-muted">Select a template to see preview</div>';
                    return;
                }

                try {
                    templatePreview.innerHTML = '<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><div class="small mt-2">Loading preview...</div></div>';
                    const response = await fetch(`/Campaigns/GetTemplate/${templateId}`);
                    if (!response.ok) throw new Error("Failed to fetch template");
                    
                    const template = await response.json();
                    renderPreview(template);
                } catch (error) {
                    templatePreview.innerHTML = `<div class="alert alert-sm alert-danger p-2 small">Error loading preview: ${error.message}</div>`;
                }
            }

            function renderPreview(template) {
                let html = `<div class="mb-3 border-bottom pb-2 d-flex justify-content-between align-items-center">
                    <span class="badge bg-primary">${template.messageType}</span>
                    <small class="text-muted">${template.name}</small>
                </div>`;
                
                try {
                    const payload = JSON.parse(template.payloadJson);
                    const content = payload.content;

                    if (content.text) {
                        html += `<div class="preview-bubble">${content.text.replace(/\n/g, '<br>')}</div>`;
                        renderSuggestions(content.suggestions, (sHtml) => html += sHtml);
                    } 
                    else if (content.richCardDetails && content.richCardDetails.standalone) {
                        const card = content.richCardDetails.standalone.cardContent;
                        html += renderCard(card);
                    } 
                    else if (content.richCardDetails && content.richCardDetails.carousel) {
                        const carousel = content.richCardDetails.carousel;
                        html += `<div class="preview-carousel">`;
                        carousel.cardContents.forEach(card => {
                            html += `<div class="preview-carousel-item">${renderCard(card)}</div>`;
                        });
                        html += `</div>`;
                    } else {
                        html += `<pre class="x-small bg-white p-2 border rounded"><code>${JSON.stringify(payload, null, 2)}</code></pre>`;
                    }
                } catch (e) {
                    html += `<div class="alert alert-warning p-2 small">Parse Error: ${e.message}</div>`;
                }
                
                templatePreview.innerHTML = html;
            }

            function renderCard(card) {
                let cardHtml = `<div class="preview-card">`;
                
                if (card.media && card.media.contentUrl) {
                    cardHtml += `<div class="preview-media"><img src="${card.media.contentUrl}" style="width:100%;height:100%;object-fit:cover;"></div>`;
                } else {
                    cardHtml += `<div class="preview-media"></div>`;
                }

                cardHtml += `<div class="preview-body">`;
                if (card.title) cardHtml += `<div class="preview-title">${card.title}</div>`;
                if (card.description) cardHtml += `<div class="preview-desc">${card.description}</div>`;
                cardHtml += `</div>`;
                
                if (card.suggestions && card.suggestions.length > 0) {
                    cardHtml += `<div class="preview-btns">`;
                    card.suggestions.forEach(s => {
                        const text = s.action ? s.action.displayText : (s.reply ? s.reply.displayText : 'Action');
                        cardHtml += `<div class="preview-btn">${text}</div>`;
                    });
                    cardHtml += `</div>`;
                }
                
                cardHtml += `</div>`;
                return cardHtml;
            }

            function renderSuggestions(suggestions, append) {
                if (!suggestions || suggestions.length === 0) return;
                let sHtml = `<div class="d-grid gap-1 mt-2">`;
                suggestions.forEach(s => {
                    const text = s.action ? s.action.displayText : (s.reply ? s.reply.displayText : 'Action');
                    sHtml += `<button type="button" class="btn btn-sm btn-outline-primary rounded-pill py-1" style="font-size: 0.7rem;">${text}</button>`;
                });
                sHtml += `</div>`;
                append(sHtml);
            }

            clientSelect.addEventListener("change", filterTemplates);
            templateSelect.addEventListener("change", updatePreview);
            filterTemplates();
        })();
    </script>
}
