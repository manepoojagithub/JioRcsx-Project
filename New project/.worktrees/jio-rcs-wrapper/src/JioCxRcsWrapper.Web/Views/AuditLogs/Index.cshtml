@model JioCxRcsWrapper.Application.Common.Pagination.PagedResult<JioCxRcsWrapper.Domain.Entities.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
    var userEmails = (Dictionary<int, string>)ViewBag.UserEmails;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Audit Logs</h1>
        <p class="text-muted mb-0">System-wide operational and security audit trail.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="DownloadCsv" class="btn btn-outline-primary">Download CSV</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Timestamp</th>
            <th>User</th>
            <th>Module</th>
            <th>Action</th>
            <th>Details</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var log in Model.Items)
        {
            <tr>
                <td class="text-nowrap">@log.Timestamp.ToLocalTime().ToString("g")</td>
                <td>@(userEmails.TryGetValue(log.UserId, out var email) ? email : log.UserId.ToString())</td>
                <td><span class="badge bg-info text-dark">@log.Module</span></td>
                <td>@log.Action</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(log.RequestPayload) || !string.IsNullOrWhiteSpace(log.ResponseJson))
                    {
                        <button type="button" class="btn btn-sm btn-link p-0" data-bs-toggle="modal" data-bs-target="#auditModal-@log.Id">
                            View Payloads
                        </button>
                        
                        <div class="modal fade" id="auditModal-@log.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Log Details - @log.Id</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <h6>Request Payload</h6>
                                        <pre class="bg-light p-2 border rounded"><code>@log.RequestPayload</code></pre>
                                        <h6 class="mt-3">Response JSON</h6>
                                        <pre class="bg-light p-2 border rounded"><code>@log.ResponseJson</code></pre>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <span class="text-muted small">N/A</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<partial name="_Pager" model="Model" />
